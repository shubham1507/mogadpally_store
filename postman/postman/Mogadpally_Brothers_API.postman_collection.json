  "item": [
    {
  "name": "01 Authentication",
  "description": "Authentication APIs using JWT",
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\":\"john@example.com\",\n    \"password\":\"Password@123\",\n    \"confirm_password\":\"Password@123\",\n    \"first_name\":\"John\",\n    \"last_name\":\"Doe\",\n    \"phone\":\"9876543210\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Creates a new customer account."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([201,400]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\":\"john@example.com\",\n    \"password\":\"Password@123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Authenticates user and returns JWT tokens."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login Successful', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.collectionVariables.set('access_token', json.access);",
              "pm.collectionVariables.set('refresh_token', json.refresh);",
              "",
              "pm.test('Access Token Saved', function(){",
              "    pm.expect(pm.collectionVariables.get('access_token')).to.not.eql('');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "profile"
          ]
        },
        "description": "Returns currently authenticated user's profile."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Profile Loaded', function(){",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh\":\"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/refresh",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "refresh"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Refresh Successful', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "if(json.access){",
              "    pm.collectionVariables.set('access_token', json.access);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh\":\"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        },
        "description": "Blacklists refresh token and logs out the user."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Logout Response', function(){",
              "    pm.expect(pm.response.code).to.be.oneOf([200,204]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
},
{
  "name": "02 Catalog",
  "description": "Catalog APIs - Categories, Products, Product Details and Filters",
  "item": [
    {
      "name": "Categories",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/categories",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "categories"
          ]
        },
        "description": "Returns all active categories."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response Time < 1000ms', function(){",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ]
        },
        "description": "Returns all available products."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "",
              "let products = [];",
              "",
              "if(data.results){",
              "    products = data.results;",
              "}else{",
              "    products = data;",
              "}",
              "",
              "pm.test('Products Returned', function(){",
              "    pm.expect(products.length).to.be.above(0);",
              "});",
              "",
              "if(products.length>0){",
              "    pm.collectionVariables.set('product_id',products[0].id);",
              "    pm.collectionVariables.set('product_slug',products[0].slug);",
              "}",
              "",
              "pm.test('Product Variables Saved', function(){",
              "    pm.expect(pm.collectionVariables.get('product_id')).to.not.eql('');",
              "    pm.expect(pm.collectionVariables.get('product_slug')).to.not.eql('');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Product Detail",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products/{{product_slug}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products",
            "{{product_slug}}"
          ]
        },
        "description": "Returns complete details of a single product."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Product Has Name', function(){",
              "    pm.expect(json.name).to.not.eql(null);",
              "});",
              "",
              "pm.test('Product Has Price', function(){",
              "    pm.expect(json.price).to.not.eql(null);",
              "});"
            ]
          }
        }
      ]
    },
        {
      "name": "Search Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products?search=oil",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "search",
              "value": "oil"
            }
          ]
        },
        "description": "Search products by keyword."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Search Success', function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response Time < 1000ms', function(){",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Category Filter",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products?category=stress-sleep",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "category",
              "value": "stress-sleep"
            }
          ]
        },
        "description": "Filter products by category slug."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Category Filter Success', function(){",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Price Filter",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products?min_price=200&max_price=350",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "min_price",
              "value": "200"
            },
            {
              "key": "max_price",
              "value": "350"
            }
          ]
        },
        "description": "Returns products within the specified price range."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Price Filter Success', function(){",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Order By Price (Ascending)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products?ordering=price",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "ordering",
              "value": "price"
            }
          ]
        },
        "description": "Returns products sorted by lowest price first."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Ordering Success', function(){",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Order By Price (Descending)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/products?ordering=-price",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "ordering",
              "value": "-price"
            }
          ]
        },
        "description": "Returns products sorted by highest price first."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Descending Order Success', function(){",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
},
{
