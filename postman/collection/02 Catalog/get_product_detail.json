{
  "name": "Get Product Details",
  "request": {
    "method": "GET",
    "header": [],
    "url": {
      "raw": "{{base_url}}/products/{{product_slug}}",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "products",
        "{{product_slug}}"
      ]
    },
    "description": "Returns complete details of a product including category, images and reviews."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "const product = pm.response.json();",
          "",
          "pm.test('Product ID exists', function () {",
          "    pm.expect(product.id).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Product name exists', function () {",
          "    pm.expect(product.name).to.not.be.empty;",
          "});",
          "",
          "pm.test('Product slug matches', function () {",
          "    pm.expect(product.slug).to.eql(pm.collectionVariables.get('product_slug'));",
          "});",
          "",
          "pm.test('Category exists', function () {",
          "    pm.expect(product.category).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Images is an array', function () {",
          "    pm.expect(product.images).to.be.an('array');",
          "});",
          "",
          "pm.test('Reviews is an array', function () {",
          "    pm.expect(product.reviews).to.be.an('array');",
          "});",
          "",
          "pm.test('Price exists', function () {",
          "    pm.expect(product.price).to.not.be.undefined;",
          "});",
          "",
          "pm.test('MRP exists', function () {",
          "    pm.expect(product.mrp).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Stock quantity exists', function () {",
          "    pm.expect(product.stock_quantity).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Description exists', function () {",
          "    pm.expect(product.description).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Response time < 1000 ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});"
        ]
      }
    }
  ]
}