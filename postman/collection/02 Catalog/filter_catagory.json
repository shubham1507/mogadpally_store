{
  "name": "Filter by Category",
  "request": {
    "method": "GET",
    "header": [],
    "url": {
      "raw": "{{base_url}}/products?category={{category_slug}}",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "products"
      ],
      "query": [
        {
          "key": "category",
          "value": "{{category_slug}}"
        }
      ]
    },
    "description": "Returns products belonging to a category."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "const products = pm.response.json();",
          "",
          "pm.test('Response is array', function(){",
          "    pm.expect(products).to.be.an('array');",
          "});",
          "",
          "pm.test('Products found', function(){",
          "    pm.expect(products.length).to.be.greaterThan(0);",
          "});"
        ]
      }
    }
  ]
}