{
  "name": "Register",
  "request": {
    "method": "POST",
    "header": [
      {
        "key": "Content-Type",
        "value": "application/json"
      }
    ],
    "body": {
      "mode": "raw",
      "raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\",\n    \"confirm_password\": \"{{user_password}}\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"Customer\",\n    \"phone\": \"{{user_phone}}\"\n}"
    },
    "url": {
      "raw": "{{base_url}}/auth/register",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "auth",
        "register"
      ]
    },
    "description": "Registers a new customer."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status code is 201', function () {",
          "    pm.response.to.have.status(201);",
          "});",
          "",
          "const json = pm.response.json();",
          "",
          "pm.test('Registration successful', function () {",
          "    pm.expect(json.message).to.eql('Registration successful.');",
          "});",
          "",
          "pm.test('User object returned', function () {",
          "    pm.expect(json.user).to.not.be.undefined;",
          "});",
          "",
          "pm.collectionVariables.set('user_id', json.user.id);",
          "",
          "pm.test('Response time < 1000 ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});"
        ]
      }
    }
  ]
}