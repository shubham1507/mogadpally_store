{
  "name": "04 Orders",
  "item": [
    {
      "name": "Checkout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/orders/checkout/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "orders",
            "checkout"
          ]
        },
        "description": "Creates an order from the authenticated user's cart."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "",
              "if(data.id){",
              "   pm.collectionVariables.set('order_id', data.id);",
              "}",
              "",
              "pm.test('Order Created', function(){",
              "    pm.expect(data.id).to.not.be.undefined;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "My Orders",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
