{
  "info": {
    "name": "Mogadpally Brothers API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "product_slug",
      "value": "chyawanprash-classic"
    },
    {
      "key": "product_id",
      "value": "REPLACE_WITH_PRODUCT_UUID"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"confirm_password\": \"Password@123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r=pm.response.json();",
                  "if(r.access) pm.collectionVariables.set('access_token',r.access);",
                  "if(r.refresh) pm.collectionVariables.set('refresh_token',r.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/profile",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\":\"{{refresh_token}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\":\"{{refresh_token}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Product Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_slug}}"
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?search=oil"
          }
        },
        {
          "name": "Category Filter",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?category=stress-sleep"
          }
        },
        {
          "name": "Price Filter",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?min_price=200&max_price=350"
          }
        },
        {
          "name": "Order By Price",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?ordering=price"
          }
        },
        {
          "name": "Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_id}}/reviews"
          }
        },
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/products/{{product_id}}/reviews",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"rating\": 5, \"comment\": \"Excellent product!\"}"
            }
          }
        }
      ]
    }
  ]
}