{
  "name": "Get Categories",
  "request": {
    "method": "GET",
    "header": [],
    "url": {
      "raw": "{{base_url}}/categories",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "categories"
      ]
    },
    "description": "Returns all parent categories."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "const data = pm.response.json();",
          "",
          "pm.test('Response is array', function () {",
          "    pm.expect(data).to.be.an('array');",
          "});",
          "",
          "pm.test('At least one category exists', function () {",
          "    pm.expect(data.length).to.be.above(0);",
          "});",
          "",
          "pm.collectionVariables.set('category_id', data[0].id);",
          "pm.collectionVariables.set('category_slug', data[0].slug);",
          "",
          "pm.test('Response time < 1000 ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});"
        ]
      }
    }
  ]
}