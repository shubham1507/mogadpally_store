{
  "name": "Create Razorpay Order",
  "request": {
    "method": "POST",
    "header": [
      {
        "key": "Authorization",
        "value": "Bearer {{access_token}}"
      },
      {
        "key": "Content-Type",
        "value": "application/json"
      }
    ],
    "body": {
      "mode": "raw",
      "raw": "{\n \"order_id\":\"{{order_id}}\"\n}"
    },
    "url": {
      "raw": "{{base_url}}/payments/razorpay/",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "payments",
        "razorpay"
      ]
    }
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status 201',function(){",
          " pm.response.to.have.status(201);",
          "});",
          "",
          "const payment=pm.response.json();",
          "",
          "pm.collectionVariables.set('payment_id',payment.id);",
          "pm.collectionVariables.set('gateway_order_id',payment.gateway_order_id);",
          "",
          "pm.test('Provider Razorpay',function(){",
          " pm.expect(payment.provider).to.eql('RAZORPAY');",
          "});",
          "",
          "pm.test('Gateway Order Exists',function(){",
          " pm.expect(payment.gateway_order_id).to.not.be.empty;",
          "});"
        ]
      }
    }
  ]
}