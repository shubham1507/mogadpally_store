{
  "name": "Profile",
  "request": {
    "method": "GET",
    "header": [
      {
        "key": "Authorization",
        "value": "Bearer {{access_token}}"
      }
    ],
    "url": {
      "raw": "{{base_url}}/auth/profile",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "auth",
        "profile"
      ]
    },
    "description": "Returns authenticated user's profile."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "const json = pm.response.json();",
          "",
          "pm.test('Email exists', function () {",
          "    pm.expect(json.email).to.not.be.undefined;",
          "});",
          "",
          "pm.test('First name exists', function () {",
          "    pm.expect(json.first_name).to.not.be.undefined;",
          "});",
          "",
          "pm.test('User ID exists', function () {",
          "    pm.expect(json.id).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Response time < 1000 ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});"
        ]
      }
    }
  ]
}