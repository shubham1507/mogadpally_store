{
  "name": "Cash On Delivery",
  "request": {
    "method": "POST",
    "header": [
      {
        "key": "Authorization",
        "value": "Bearer {{access_token}}"
      },
      {
        "key": "Content-Type",
        "value": "application/json"
      }
    ],
    "body": {
      "mode": "raw",
      "raw": "{\n    \"order_id\":\"{{order_id}}\"\n}"
    },
    "url": {
      "raw": "{{base_url}}/payments/cod/",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "payments",
        "cod"
      ]
    }
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status 201', function(){",
          " pm.response.to.have.status(201);",
          "});",
          "",
          "const payment=pm.response.json();",
          "",
          "pm.collectionVariables.set('payment_id',payment.id);",
          "",
          "pm.test('Provider COD',function(){",
          " pm.expect(payment.provider).to.eql('COD');",
          "});",
          "",
          "pm.test('Status SUCCESS',function(){",
          " pm.expect(payment.status).to.eql('SUCCESS');",
          "});"
        ]
      }
    }
  ]
}