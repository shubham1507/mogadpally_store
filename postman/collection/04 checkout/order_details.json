{
  "name": "Order Details",
  "request": {
    "method": "GET",
    "header": [
      {
        "key": "Authorization",
        "value": "Bearer {{access_token}}"
      }
    ],
    "url": {
      "raw": "{{base_url}}/orders/{{order_id}}/",
      "host": [
        "{{base_url}}"
      ],
      "path": [
        "orders",
        "{{order_id}}"
      ]
    },
    "description": "Returns complete order information."
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Status 200', function(){",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "const order = pm.response.json();",
          "",
          "pm.test('Items exist', function(){",
          "    pm.expect(order.items).to.be.an('array');",
          "});",
          "",
          "pm.test('Total exists', function(){",
          "    pm.expect(order.total).to.not.be.undefined;",
          "});",
          "",
          "pm.test('Status exists', function(){",
          "    pm.expect(order.status).to.not.be.undefined;",
          "});"
        ]
      }
    }
  ]
}